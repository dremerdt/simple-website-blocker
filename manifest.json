{
  "manifest_version": 3,
  "name": "Simple Website Blocker",
  "version": "1.4",
  "description": "Block websites permanently, temporarily, or on a weekly schedule.",
  "permissions": ["storage", "declarativeNetRequest", "activeTab", "alarms"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/toolbar_16.png",
      "32": "images/toolbar_32.png"
    }
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "manage/manage.html",
  "icons": {
    "16": "images/icon_16.png",
    "32": "images/icon_32.png",
    "48": "images/icon_48.png",
    "128": "images/icon_128.png"
  },
  "host_permissions": [
    "*://*/*"
  ]
}
